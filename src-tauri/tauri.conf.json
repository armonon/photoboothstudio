{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Model Studio",
  "version": "0.3.0",
  "identifier": "com.armonon.modelstudio",
  "build": {
    "beforeBuildCommand": "npm run build:desktop",
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "Model Studio",
        "width": 1100,
        "height": 820,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
