# Image AI — turns an uploaded garment photo into a polished product mockup (AI mode).
# Get a Gemini API key at https://aistudio.google.com/apikey
# Read by both /api/enhance (local) and the Netlify background function (deployed).
# Free background-removal mode needs none of this — it runs in the browser.
IMAGE_AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
