# Image AI — turns an uploaded garment photo into a polished product mockup.
# Get a Gemini API key at https://aistudio.google.com/apikey
# Read by both /api/enhance (local) and the Netlify background function (deployed).
IMAGE_AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Asset storage (Cloudflare R2 — zero egress)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=model-studio-assets

# Database (Postgres — Neon/Supabase free tier)
DATABASE_URL=
