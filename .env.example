# Shopify (Admin API, used only to attach exported assets to a DRAFT product)
SHOPIFY_SHOP=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=

# Asset storage (Cloudflare R2 — zero egress)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=model-studio-assets

# Database (Postgres — Neon/Supabase free tier)
DATABASE_URL=
